# ---------- Global ----------
APP_ENV=development
LOG_LEVEL=INFO

# ---------- Backend ----------
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:3000

# SQLite path used by backend service
SQLITE_DB_PATH=data/rural_assistant.db

# Optional cloud providers (leave empty to run local/offline mode)
OPENAI_API_KEY=
HF_API_TOKEN=
GOOGLE_API_KEY=
GOOGLE_TTS_API_KEY=

# Feature toggles
ENABLE_LLM=true
ENABLE_CLOUD_TTS=true
ENABLE_OFFLINE_FALLBACK=true
ENABLE_LIVE_WEATHER=true
WEATHER_CACHE_TTL_MIN=90
RATE_LIMIT_WINDOW_SEC=60
RATE_LIMIT_MAX_REQUESTS=30

# ---------- Frontend ----------
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_DEFAULT_LANGUAGE=hi
NEXT_PUBLIC_APP_NAME=ग्रामीण सहायक
